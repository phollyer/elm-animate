{
    "type": "package",
    "name": "phollyer/elm-smooth-move",
    "summary": "Smooth moving animation for DOM elements",
    "license": "BSD-3-Clause",
    "version": "3.0.0",
    "exposed-modules": [
        "Scroll",
        "Scroll.Document.Cmd",
        "Scroll.Document.Task",
        "Scroll.Container.Cmd",
        "Scroll.Container.Task",
        "Anim",
        "Anim.CSS",
        "Anim.Sub",
        "Anim.Ports",
        "Anim.Timing.Easing",
        "Anim.Timing.TimeSpec",
        "Anim.Timing.Delay",
        "Anim.Properties.Position",
        "Anim.Properties.Rotation",
        "Anim.Properties.Scale",
        "Anim.Properties.Opacity",
        "Anim.Properties.Color"
    ],
    "elm-version": "0.19.0 <= v < 0.20.0",
    "dependencies": {
        "elm/browser": "1.0.0 <= v < 2.0.0",
        "elm/core": "1.0.0 <= v < 2.0.0",
        "elm/html": "1.0.0 <= v < 2.0.0",
        "elm/json": "1.0.0 <= v < 2.0.0",
        "elm-community/easing-functions": "2.0.0 <= v < 3.0.0"
    },
    "test-dependencies": {
        "elm-explorations/test": "2.0.0 <= v < 3.0.0"
    }
}