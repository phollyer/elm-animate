{
    "type": "package",
    "name": "phollyer/elm-animate",
    "summary": "Smooth moving animation and scrolling for DOM elements",
    "license": "BSD-3-Clause",
    "version": "3.0.1",
    "exposed-modules": [
        "Anim.Engine.CSS",
        "Anim.Engine.Sub",
        "Anim.Engine.WAAPI",
        "Anim.Engine.Scroll",
        "Anim.Timing.Easing",
        "Anim.Timing.TimeSpec",
        "Anim.Timing.Delay",
        "Anim.Properties.Position",
        "Anim.Properties.Rotate",
        "Anim.Properties.Scale",
        "Anim.Properties.Opacity",
        "Anim.Properties.BackgroundColor",
        "Anim.Properties.Size"
    ],
    "elm-version": "0.19.0 <= v < 0.20.0",
    "dependencies": {
        "avh4/elm-color": "1.0.0 <= v < 2.0.0",
        "elm/browser": "1.0.0 <= v < 2.0.0",
        "elm/core": "1.0.0 <= v < 2.0.0",
        "elm/html": "1.0.0 <= v < 2.0.0",
        "elm/json": "1.0.0 <= v < 2.0.0",
        "elm-community/easing-functions": "2.0.0 <= v < 3.0.0"
    },
    "test-dependencies": {
        "elm-explorations/test": "2.0.0 <= v < 3.0.0"
    }
}
