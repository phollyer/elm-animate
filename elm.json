{
    "type": "package",
    "name": "phollyer/elm-animate",
    "summary": "Smooth moving animation and scrolling for DOM elements",
    "license": "BSD-3-Clause",
    "version": "3.0.1",
    "exposed-modules": [
        "Anim.Builder",
        "Anim.Engine.CSS.Transition",
        "Anim.Engine.CSS.Keyframe",
        "Anim.Engine.Sub",
        "Anim.Engine.WAAPI",
        "Anim.Engine.Scroll.Builder",
        "Anim.Engine.Scroll.Cmd",
        "Anim.Engine.Scroll.Sub",
        "Anim.Engine.Scroll.Task",
        "Anim.Extra.Color",
        "Anim.Extra.Easing",
        "Anim.Extra.TransformOrder",
        "Anim.Extra.View3D",
        "Anim.Property.Translate",
        "Anim.Property.Rotate",
        "Anim.Property.Scale",
        "Anim.Property.Opacity",
        "Anim.Property.BackgroundColor",
        "Anim.Property.FontColor",
        "Anim.Property.Size"
    ],
    "elm-version": "0.19.0 <= v < 0.20.0",
    "dependencies": {
        "avh4/elm-color": "1.0.0 <= v < 2.0.0",
        "elm/browser": "1.0.0 <= v < 2.0.0",
        "elm/core": "1.0.0 <= v < 2.0.0",
        "elm/html": "1.0.0 <= v < 2.0.0",
        "elm/json": "1.0.0 <= v < 2.0.0",
        "elm-community/easing-functions": "2.0.0 <= v < 3.0.0"
    },
    "test-dependencies": {
        "elm-explorations/test": "2.0.0 <= v < 3.0.0"
    }
}