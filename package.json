{
  "name": "elm-animate-waapi",
  "version": "1.0.0",
  "description": "JavaScript companion for elm-animate WAAPI API - Web Animations integration",
  "type": "module",
  "main": "dist/elm-animate-waapi.js",
  "module": "dist/elm-animate-waapi.mjs",
  "exports": {
    ".": {
      "import": "./dist/elm-animate-waapi.mjs",
      "require": "./dist/elm-animate-waapi.js"
    }
  },
  "files": [
    "dist/elm-animate-waapi.js",
    "dist/elm-animate-waapi.mjs",
    "dist/elm-animate-waapi.d.ts",
    "dist/LICENSE",
    "dist/README.md"
  ],
  "scripts": {
    "build": "test -f dist/elm-animate-waapi.js && test -f dist/elm-animate-waapi.mjs",
    "prepare": "mkdir -p dist && npm run build"
  },
  "keywords": [
    "elm",
    "animation",
    "web-animations",
    "smooth-scroll",
    "ports",
    "javascript"
  ],
  "author": "phollyer",
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/phollyer/elm-animate.git"
  },
  "homepage": "https://github.com/phollyer/elm-animate#readme",
  "dependencies": {
    "elm-doc-preview": "^6.0.1",
    "scroll-timeline-polyfill": "^1.1.0"
  },
  "devDependencies": {},
  "peerDependencies": {}
}